<!DOCTYPE html>

<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Отчет по логам</title>


<style>
    body {
        font-family: Arial, sans-serif;
        margin: 30px;
        background: #f4f6f8;
        color: #333;
    }

    h1, h2 {
        color: #1f2937;
    }

    .card {
        background: white;
        padding: 20px;
        margin-bottom: 25px;
        border-radius: 8px;
        box-shadow: 0 2px 6px rgba(0,0,0,.08);
    }

    table {
        width: 100%;
        border-collapse: collapse;
    }

    th {
        background: #374151;
        color: white;
        padding: 10px;
        text-align: left;
    }

    td {
        border-bottom: 1px solid #ddd;
        padding: 10px;
    }

    tr:hover {
        background: #f9fafb;
    }

    .summary {
        display: flex;
        flex-wrap: wrap;
        gap: 15px;
    }

    .summary-item {
        background: #ffffff;
        border-radius: 8px;
        padding: 15px;
        min-width: 140px;
        text-align: center;
        box-shadow: 0 1px 4px rgba(0,0,0,.1);
    }

    .summary-value {
        font-size: 28px;
        font-weight: bold;
    }

    .error {
        color: #dc2626;
    }

    .warning {
        color: #d97706;
    }

    .success {
        color: #059669;
    }

    .small {
        font-size: 12px;
        color: gray;
    }

    ul {
        padding-left: 20px;
    }

    li {
        margin-bottom: 6px;
    }
</style>


</head>
<body>

    <h1>Отчет по логам</h1>

    <div class="card">

        <h2>Статистика по ошибкам</h2>

        <div class="summary">

            <div class="summary-item">
                <div>Всего событий</div>
                <div class="summary-value">
                    {{ stats.total }}
                </div>
            </div>

            <div class="summary-item">
                <div>INFO</div>
                <div class="summary-value success">
                    {{ stats.info }}
                </div>
            </div>

            <div class="summary-item">
                <div>WARNING</div>
                <div class="summary-value warning">
                    {{ stats.warning }}
                </div>
            </div>

            <div class="summary-item">
                <div>ERROR</div>
                <div class="summary-value error">
                    {{ stats.error }}
                </div>
            </div>

            <div class="summary-item">
                <div>CRITICAL</div>
                <div class="summary-value error">
                    {{ stats.critical }}
                </div>
            </div>

            <div class="summary-item">
                <div>TIMEOUT</div>
                <div class="summary-value error">
                    {{ stats.timeout }}
                </div>
            </div>

        </div>
    </div>

    <div class="card">

        <h2>Инциденты: ({{ stats.problem_levels }})</h2>

        <p>
            Общее количество проблемных событий:
            <strong>{{ stats.problem_events }}</strong>
        </p>


    </div>

    <div class="card">
        <h2>Топ 10 ошибок</h2>


        <table>
            <thead>
            <tr>
                <th>Сообщение</th>
                <th>Кол-во</th>
            </tr>
            </thead>

            <tbody>

            {% for message, count in stats.top_errors %}
            <tr>
                <td>{{ message }}</td>
                <td>{{ count }}</td>
            </tr>
            {% endfor %}

            </tbody>
        </table>


    </div>

    <div class="card">
        <h2>Статистика по файлам</h2>


        <table>
            <thead>
            <tr>
                <th>Файл</th>
                <th>Всего</th>
                <th>INFO</th>
                <th>WARNING</th>
                <th>ERROR</th>
                <th>CRITICAL</th>
                <th>TIMEOUT</th>
            </tr>
            </thead>

            <tbody>

            {% for filename, file_stat in stats.files.items() %}
            <tr>
                <td>{{ filename }}</td>
                <td>{{ file_stat.total }}</td>
                <td>{{ file_stat.info }}</td>
                <td>{{ file_stat.warning }}</td>
                <td>{{ file_stat.error }}</td>
                <td>{{ file_stat.critical }}</td>
                <td>{{ file_stat.timeout }}</td>
            </tr>
            {% endfor %}

            </tbody>
        </table>


    </div>

    <div class="card">


        <h2>Ошибочные строки</h2>

        <p>
            Всего ошибочных строк:
            <strong>{{ invalid_lines|length }}</strong>
        </p>

        {% if invalid_lines %}

            <table>
                <thead>
                <tr>
                    <th>Файл</th>
                    <th>Строка</th>
                    <th>Содержимое</th>
                </tr>
                </thead>

                <tbody>

                {% for item in invalid_lines %}
                <tr>
                    <td>{{ item.filename }}</td>
                    <td>{{ item.line_number }}</td>
                    <td>{{ item.content }}</td>
                </tr>
                {% endfor %}

                </tbody>
            </table>

        {% endif %}


    </div>

</body>
</html>
